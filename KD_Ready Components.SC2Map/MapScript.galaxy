//--------------------------------------------------------------------------------------------------
// Trigger: Random Shadow of the Hybrids Gamemode
//--------------------------------------------------------------------------------------------------
bool lib1_gt_RandomShadowoftheHybridsGamemode_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!(((lib1_gv_gamemodeSeed >= 56) && (lib1_gv_gamemodeSeed <= 67)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(5.0, c_timeGame);
    TriggerExecute(lib1_gt_ShadowoftheHybridsGamemode, false, false);
    return true;
}

